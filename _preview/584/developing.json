xt","value":". You may find it easier to work with your data in a dictionary or tuple. For the single dimension of “date” and metric of “activeUsers” as specified in our example function, here is what your data manipulation may look like before you can carry out additional analysis.","position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"key":"qyhh7nqffo"}],"key":"pdSUc3602K"},{"type":"code","lang":"","value":"dates=[]\nusers=[]\nfor row in response.rows:\n    date_str = row.dimension_values[0].value\n    date = datetime.datetime.strptime(date_str, '%Y%m%d')\n    dates.append(date)\n    users.append(int(row.metric_values[0].value))\n\ndates, users =  zip(*sorted(zip(dates, user_counts), key=lambda x: x[0]))","position":{"start":{"line":140,"column":1},"end":{"line":150,"column":1}},"key":"IKKrOl9Pb9"},{"type":"paragraph","position":{"start":{"line":152,"column":1},"end":{"line":152,"column":1}},"children":[{"type":"text","value":"One thing to note is that your Analytics response rows are not automatically chronological, so in this example we zipped our sorted tuple to ensure that the dates are in the expected order.","position":{"start":{"line":152,"column":1},"end":{"line":152,"column":1}},"key":"gTp8gTgYyG"}],"key":"zBiEwbnJGN"}],"key":"fYMmpufk93"}],"key":"zOcScuCk2e"}],"key":"yELAMLw3WT"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Contributing to Project Pythia","url":"/contributing","group":"2023"},"next":{"title":"Contributing a New Cookbook","url":"/cookbook-guide","group":"2023"}}},"domain":"http://localhost:3000"}