 (based on ","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"G7eIdtth86"},{"type":"link","url":"https://repo2docker.readthedocs.io/en/latest/","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"repo2docker","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"aVI8Uiz1ZI"}],"urlSource":"https://repo2docker.readthedocs.io/en/latest/","key":"aIWawW4ZIV"},{"type":"text","value":"). This allowed each breakout group to build and deploy their own unique hub environment. Groups could then tailor their environment to the needs of their Cookbook but still work in a common shared space.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"hv8D0sGy9y"}],"key":"Y37huo7hAW"},{"type":"paragraph","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"children":[{"type":"text","value":"Special thanks and gratitude go to ","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"key":"SvUKGerjhG"},{"type":"link","url":"https://2i2c.org/author/angus-hollands/","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"children":[{"type":"text","value":"Angus Hollands","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"key":"uxtm9VRUs8"}],"urlSource":"https://2i2c.org/author/angus-hollands/","key":"YkooCdCu37"},{"type":"text","value":" for working through some day 1 technical glitches in real time from a very different timezone!","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"key":"tan0PhICTD"}],"key":"aLWqT1rhq4"},{"type":"heading","depth":3,"position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Breakout group logistics","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"n6VxNnOJG7"}],"identifier":"breakout-group-logistics","label":"Breakou