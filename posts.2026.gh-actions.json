{"version":3,"kind":"Article","sha256":"a082dbf4a3ebbec440fecacb67a0f99c26a603d162a7b021dd315239b09e1c17","slug":"posts.2026.gh-actions","location":"/posts/2026/gh-actions.md","dependencies":[],"frontmatter":{"title":"When a GitHub Shadowban Breaks Open Source Infrastructure","description":"What I learned after discovering my GitHub account had been shadowbanned, and how it broke our link checks.","subtitle":"Overhauling our GitHub Actions to Reduce Compute Minutes and Ghost Commits","tags":["github","actions"],"authors":[{"id":"jukent","nameParsed":{"literal":"Julia Kent","given":"Julia","family":"Kent"},"name":"Julia Kent","orcid":"0000-0002-5611-8986","affiliations":["CISL"],"github":"jukent"}],"date":"2026-05-20","open_access":true,"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true},"code":{"id":"Apache-2.0","url":"https://opensource.org/licenses/Apache-2.0","name":"Apache License 2.0","free":true,"osi":true}},"github":"https://github.com/projectpythia/projectpythia.github.io","affiliations":[{"id":"CISL","name":"NSF National Center for Atmospheric Research","department":"Computational and Information Systems Lab","url":"https://www.cisl.ucar.edu"},{"id":"UAlbany","name":"University at Albany (SUNY)","department":"Atmospheric and Environmental Sciences","url":"https://www.albany.edu/daes"},{"id":"Unidata","name":"NSF Unidata","url":"https://www.unidata.ucar.edu"},{"id":"Argonne","name":"Argonne National Laboratory","department":"Environmental Science Division","url":"https://www.anl.gov/evs"},{"id":"CarbonPlan","name":"CarbonPlan","url":"https://carbonplan.org"},{"id":"NVIDIA","name":"NVIDIA Corporation","url":"https://www.nvidia.com/"},{"id":"2i2c","name":"2i2c","url":"https://2i2c.org"}],"numbering":{"title":{"offset":2}},"source_url":"https://github.com/projectpythia/projectpythia.github.io/blob/main/portal/posts/2026/gh-actions.md","edit_url":"https://github.com/projectpythia/projectpythia.github.io/edit/main/portal/posts/2026/gh-actions.md","thumbnail":"/build/copilot-minutes-6f3620174791582df05134953216db1f.png","exports":[{"format":"md","filename":"gh-actions.md","url":"/build/gh-actions-16e9b8df16da969ab32ed2c46a5f2949.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Early April, I discovered that my GitHub account was shadowbanned.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"LqR0EaO2rP"}],"key":"mif0tSK6Tu"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"First, I only noticed that links to pull requests I had opened were failing our link checker. But the issue was much larger.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"gEQzNeZ93O"}],"key":"gSn2aKW8un"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"From my side, everything looked normal, but my coworkers were unable to see or interact with my account. I reached out to GitHub for support and was told that they would not be “removing the restrictions from this account.” All of a sudden, this small issue seemed insurmountable.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"zwhTMqX37H"}],"key":"jo8fot3RaI"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"The closest explanation I received referenced GitHub’s Additional Product Terms for Actions:","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"xnQND7DvBM"}],"key":"DMBXOxFk4W"},{"type":"blockquote","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"“Any repositories that use GitHub Actions solely to interact with 3rd party websites, to engage in incentivized activities, or for general computing purposes may fall afoul of the GitHub Additional Product Terms.”","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"UupDQViJyP"}],"key":"cBbNlLElmd"}],"key":"ThowNUqPTx"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"I have not used GitHub Actions for cryptomining, unauthorized access, commercial activity, or unrelated computing tasks. Everything I configured was in service of open-source scientific infrastructure through Project Pythia and National Center for Atmospheric Research.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"WU3XSiD7tO"}],"key":"NnihnXTq97"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"I found and posted on forums and help requests, learning:","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"r5A1NEJLYQ"}],"key":"ypcmJUCKAN"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":23,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"It is GitHub’s policy to not inform anyone of their account being banned and","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"xE71QkmJKf"}],"key":"pntsxAcBFC"}],"key":"TUPEasQIME"},{"type":"listItem","spread":true,"position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"This problem is so common that r/github has a 2 year old ","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"wVxeaQkURH"},{"type":"link","url":"https://www.reddit.com/r/github/comments/1er6iwo/was_your_account_suspended_deleted_or/","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"stickied “shadowbanned for no reason?” thread","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"W5ECgQ9JWY"}],"urlSource":"https://www.reddit.com/r/github/comments/1er6iwo/was_your_account_suspended_deleted_or/","key":"a754Vsev0a"},{"type":"text","value":" (and you will be banned from that community too if you ask for support out of that thread),","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"LRRqrGSI2j"}],"key":"tBvQEI2xCQ"}],"key":"DtJZ3UMvox"},{"type":"listItem","spread":true,"position":{"start":{"line":25,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"There is a ","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"O2BySrIEPN"},{"type":"link","url":"https://github.com/orgs/community/discussions/136618","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"GitHub community discussion page for banned accounts","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"d9PStT1UgN"}],"urlSource":"https://github.com/orgs/community/discussions/136618","error":true,"key":"yPQWa72yka"},{"type":"text","value":", where, ironically, you can only see comments from accounts that have had the ban lifted.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"km89Lp3pzF"}],"key":"MHFsIXjQkc"}],"key":"lzEULBJJOi"}],"key":"nnsTXVmTR2"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","valu