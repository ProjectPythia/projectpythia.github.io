olumn":1}},"key":"lKgydMMwxR"}],"key":"JvL8D5nQnm"}],"key":"G48dQiBImm"},{"type":"listItem","spread":true,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"I cannot merge team member pull requests,","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"Pf7fEe02Jk"}],"key":"pJoWKX7cZz"}],"key":"aTclcFzsOL"},{"type":"listItem","spread":true,"position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"I cannot request a review on a pull request,","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"V3j5fgBhEL"}],"key":"uR82oQrwrs"}],"key":"aKkFgjJOuz"},{"type":"listItem","spread":true,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Pull requests I’ve opened have disappeared (even merged ones that should belong to the project),","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"dCM6tZcHEh"}],"key":"uZcAJL6rrR"}],"key":"qOcyykIhmW"},{"type":"listItem","spread":true,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"I cannot contribute to conversations on issues,","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"czDpIWRWt4"}],"key":"cM3wUu4R7j"}],"key":"diLqrfucJO"},{"type":"listItem","spread":true,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Issues I opened have disappeared,","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"zLdrDSjqzk"}],"key":"PDmze7Tj8b"}],"key":"nkN16d2JlF"},{"type":"listItem","spread":true,"position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"team member’s contributions as comments on issues I’ve opened have disappeared,","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"QHpjrNGJ1i"}],"key":"zbKIiTxnWK"}],"key":"xYP4aMJO8r"},{"type":"listItem","spread":true,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Links in our project are failing as we may point to a specific merged pull request that has disappeared or to my GitHub account page,","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"yDbzLZYntU"}],"key":"JUYDrkPRIc"}],"key":"b0Xt8YQbSQ"},{"type":"listItem","spread":true,"position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"There are major impacts on iteration prioritization and planning (not knowing if/when I will be able to contribute, and also issues assigned to/created by/commented on by me do not have accurate status information if they appear at all),","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"lZ2tiNmpMI"}],"key":"mvDmKxMbCm"}],"key":"mEK8ll5nfF"},{"type":"listItem","spread":true,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"I am no longer listed as a contributor in any open source project,","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"KgPcO7X9ZY"}],"key":"p1CZmRYNmF"}],"key":"FeuJTQS2HX"},{"type":"listItem","spread":true,"position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"I cannot record onboarding videos that leverage GitHub for the upcoming Pythia hackathon,","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"eLh7O04DjI"}],"key":"I6bpHDrIJ8"}],"key":"YmW5naXR21"},{"type":"listItem","spread":true,"position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"My GitHub account is linked to authorization for certain cloud services (JetStream2 for the Pythia hackathon) which I no longer have access to,","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"ChpVKmVYTk"}],"key":"BKbySBDNvY"}],"key":"lDFiW0i4JV"},{"type":"listItem","spread":true,"position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The project is potentially using GitHub actions in a way that has too high of a burden and without insight, any other team member’s are at risk of repeating the behavior that flagged my account,","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"rUggUETP4v"}],"key":"JnV9ETaewR"}],"key":"ajItlmaPys"},{"type":"listItem","spread":true,"position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Any websites I’m hosting for personal projects are down,","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"H6MuUNpOlX"}],"key":"UGBzYGuWYY"}],"key":"HEh91y2ERY"},{"type":"listItem","spread":true,"position":{"start":{"line":49,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"My portfolio is essentially up in flames.","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"xLUvkHH2QI"}],"key":"xcP2qQkP8z"}],"key":"kkDyy3JUFF"}],"key":"GTvGf2qGN6"},{"type":"paragraph","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"text","value":"Some of these consequences are unexpected; specifically, the idea that merged pull requests associated with my account are not owned by the ProjectPythia GitHub organization, making team members unable to look at commits to main authored by me.","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"key":"gZ3MvWNgah"}],"key":"IaFYJp3rLv"},{"type":"paragraph","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"text","value":"For open-source scientific projects, this becomes an infrastructure problem. This and the lack of communication is particularly devastating, because ","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"Go30xovz5z"},{"type":"strong","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"text","value":"how can we teach GitHub best practices if we are unknowingly violating them.","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"jswoOaN63s"}],"key":"wFbYnAfGjP"}],"key":"E2BqlRJOr6"},{"type":"heading","depth":2,"position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"The Possible Cause","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"ipVbaKbAAp"}],"identifier":"the-possible-cause","label":"The Possible Cause","html_id":"the-possible-cause","implicit":true,"key":"q7rB8YcOvs"},{"type":"paragraph","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"children":[{"type":"text","value":"From what I can gather there are three main theories why a GitHub account can be targeted: Copilot usage, Actions minutes usage, and too many commits.","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"key":"Ti6qMAKSBv"}],"key":"UsGRtVQGLf"},{"type":"heading","depth":3,"position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"1. Copilot Usage","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"dHfUAiKClH"}],"identifier":"id-1-copilot-usage","label":"1. Copilot Usage","html_id":"id-1-copilot-usage","implicit":true,"key":"Bc95IKAh4C"},{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"There seems to have been a mass shadowbanning of GitHub accounts due to copilot usage. My connection at GitHub suggested that this was the likely culprit.","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"lhTQkYyuiq"}],"key":"a0AQXkhQfz"},{"type":"paragraph","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"But that seems unlikely to me, with my literally minimal usage:","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"gzfRJAtL5p"}],"key":"X7ugfp0KcO"},{"type":"image","url":"/build/copilot-minutes-6f3620174791582df05134953216db1f.png","alt":"0 Copilot Minutes","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"bKIJXDTNTS","urlSource":"../../_static/images/posts/gh-actions/copilot-minutes.png"},{"type":"heading","depth":3,"position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"2. Actions minutes","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"pYrRUmojH0"}],"identifier":"id-2-actions-minutes","label":"2. Actions minutes","html_id":"id-2-actions-minutes","implicit":true,"key":"pJjIzvsoyj"},{"type":"paragraph","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"children":[{"type":"text","value":"For years, we have used Actions to:","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"key":"hcQ1qeKAEz"}],"key":"a6Rt8w79Wg"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":71,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"children":[{"t